# Sunucu
PORT=3000

# Meta webhook doğrulaması sırasında Meta App Dashboard'a girdiğiniz string
# (siz belirlersiniz, rastgele güçlü bir değer seçin)
META_VERIFY_TOKEN=degistirin_bu_gizli_bir_deger

# Meta App Dashboard > Settings > Basic > App Secret
# Webhook imza doğrulaması (X-Hub-Signature-256) için ZORUNLU - production'da boş bırakmayın
META_APP_SECRET=

# Sağladığınız Page/System User access token (Graph API'den lead detayı çekmek için)
META_ACCESS_TOKEN=EAALf41xGZADQBQ...

# IFCO'dan AYRICA alınacak API token (bu, Meta token'ından farklıdır)
IFCO_API_TOKEN=

IFCO_API_BASE=https://www.ifco.com.tr/api/meta-api
GRAPH_API_VERSION=v20.0
